kind: saml
version: v2
metadata:
  name: okta
spec:
  display: "Okta"
  acs: "https://{{ teleport_domain }}/v1/webapi/saml/acs/okta"
  entity_descriptor_url: "{{ okta_metadata_url }}"
  attributes_to_roles:
    # Wildcard: every Okta user gets base regardless of group.
    # Ensures all authenticated users start with zero standing privilege.
    - { name: "groups", value: "*",                        roles: ["base"] }
    # Editor group: full editor + access standing privileges (unchanged).
    - { name: "groups", value: "{{ okta_groups_editor }}", roles: ["editor", "access"] }
    # Access group: mapped to okta_base only — no standing privileges.
    # Users must submit an Access Request for okta_ssh, okta_kube, or okta_ssh_root.
    - { name: "groups", value: "{{ okta_groups_access }}", roles: ["okta_base"] }
