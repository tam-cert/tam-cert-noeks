clusterName: grant-tam-teleport.gvteleport.com

chartMode: standalone

enterprise: true

persistence:
  enabled: false

acme: false

proxyListenerMode: multiplex

# ── Authentication ─────────────────────────────────────────────────────────────
authentication:
  type: saml
  connectorName: okta
  localAuth: true
  secondFactors:
    - otp
    - webauthn
  webauthn:
    rpID: grant-tam-teleport.gvteleport.com

# ── Service ────────────────────────────────────────────────────────────────────
# The Helm chart does not support pinning nodePort via values (known limitation).
# NodePort 32443 is pinned via kubectl patch in the Ansible teleport role
# after helm install completes.
service:
  type: NodePort

auth:
  teleportConfig:
    teleport:
      log:
        output: stderr
        severity: INFO
      storage:
        type: postgresql
        conn_string: "postgresql://teleport@postgres-service.postgres.svc.cluster.local:5432/teleport_backend?sslmode=verify-full&sslcert=/pg-certs/client.crt&sslkey=/pg-certs/client.key&sslrootcert=/pg-certs/ca.crt&pool_max_conns=10"
        audit_events_uri:
          - "postgresql://teleport@postgres-service.postgres.svc.cluster.local:5432/teleport_audit?sslmode=verify-full&sslcert=/pg-certs/client.crt&sslkey=/pg-certs/client.key&sslrootcert=/pg-certs/ca.crt&pool_max_conns=10"
        audit_sessions_uri: "s3://{{ sessions_bucket }}/sessions?region=us-west-2"

  extraVolumes:
    - name: pg-client-certs
      secret:
        secretName: teleport-pg-client-certs
        defaultMode: 0600

  extraVolumeMounts:
    - name: pg-client-certs
      mountPath: /pg-certs
      readOnly: true

proxy:
  teleportConfig:
    teleport:
      log:
        output: stderr
        severity: INFO
    proxy_service:
      https_keypairs_reload_interval: 12h

highAvailability:
  replicaCount: 1
  requireAntiAffinity: false
