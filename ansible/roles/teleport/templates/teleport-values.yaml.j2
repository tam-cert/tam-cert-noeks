clusterName: grant-tam-teleport.gvteleport.com

chartMode: standalone

enterprise: true

persistence:
  enabled: false

acme: true
acmeEmail: grant.voss@goteleport.com

proxyListenerMode: multiplex

auth:
  teleportConfig:
    teleport:
      log:
        output: stderr
        severity: INFO
      storage:
        type: postgresql
        # In-cluster PostgreSQL pod — cert authentication, no password.
        # CN of client cert matches PostgreSQL username 'teleport'.
        # pg_hba.conf enforces: hostssl ... teleport ... cert clientcert=verify-full
        conn_string: "postgresql://teleport@postgres-service.postgres.svc.cluster.local:5432/teleport_backend?sslmode=verify-full&sslcert=/pg-certs/client.crt&sslkey=/pg-certs/client.key&sslrootcert=/pg-certs/ca.crt&pool_max_conns=20"
        audit_events_uri:
          - "postgresql://teleport@postgres-service.postgres.svc.cluster.local:5432/teleport_audit?sslmode=verify-full&sslcert=/pg-certs/client.crt&sslkey=/pg-certs/client.key&sslrootcert=/pg-certs/ca.crt"
        audit_sessions_uri: "s3://{{ sessions_bucket }}/sessions?region=us-west-2"

    auth_service:
      authentication:
        type: saml
        connector_name: okta
        local_auth: true
        # Use second_factors (plural) — Teleport 18.x deprecates second_factor
        # Setting both causes a conflict error on startup
        second_factors:
          - otp
          - webauthn
        webauthn:
          rp_id: grant-tam-teleport.gvteleport.com

  # Mount the client certs Secret (created by postgres Ansible role) into the auth pod
  extraVolumes:
    - name: pg-client-certs
      secret:
        secretName: teleport-pg-client-certs
        defaultMode: 0600

  extraVolumeMounts:
    - name: pg-client-certs
      mountPath: /pg-certs
      readOnly: true

proxy:
  teleportConfig:
    teleport:
      log:
        output: stderr
        severity: INFO
    proxy_service:
      https_keypairs_reload_interval: 12h

highAvailability:
  replicaCount: 1
  requireAntiAffinity: false

service:
  spec:
    externalTrafficPolicy: Local
    allocateLoadBalancerNodePorts: true
    healthCheckNodePort: 32444
  ports:
    - name: tls
      port: 443
      targetPort: 3080
      protocol: TCP
      nodePort: 32443
    - name: diag
      port: 3000
      targetPort: 3000
      protocol: TCP
